# ═══════════════════════════════════════════════════════════════════════════
# AutoResearch — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════
# This is the ONLY file you need to edit to switch between LLM providers.
# Copy this to .env and fill in your API key + model preferences.
#
# The system is fully LLM-agnostic: any provider supported by LiteLLM
# (100+ providers) works without code changes.
# ═══════════════════════════════════════════════════════════════════════════

# ── LLM Provider Mode ─────────────────────────────────────────────────────
# "litellm" (default) — routes to any provider via LiteLLM.
#                        Just set the right API key and model name.
# "openai"            — direct OpenAI SDK (if you only use OpenAI)
# "deepseek"          — direct DeepSeek SDK
# "local"             — local models via Ollama or compatible endpoint
LLM_MODE=litellm

# ── API Keys ──────────────────────────────────────────────────────────────
# Only set the key for the provider(s) you want to use.
# LiteLLM auto-detects which key to use based on the model name prefix.

# OpenAI (gpt-4o, gpt-4.1, o3, etc.)
# OPENAI_API_KEY=sk-YOUR-KEY-HERE

# Google Gemini (gemini/gemini-2.5-flash, gemini/gemini-2.5-pro, etc.) — FREE TIER AVAILABLE
# GEMINI_API_KEY=YOUR-KEY-HERE

# Anthropic (anthropic/claude-sonnet-4-5, etc.)
# ANTHROPIC_API_KEY=sk-ant-YOUR-KEY-HERE

# DeepSeek (deepseek/deepseek-chat, deepseek/deepseek-reasoner) — VERY AFFORDABLE
# DEEPSEEK_API_KEY=sk-YOUR-KEY-HERE

# Groq (groq/llama-3.3-70b-versatile, etc.) — FREE TIER AVAILABLE
# GROQ_API_KEY=gsk_YOUR-KEY-HERE

# Together AI (together_ai/meta-llama/..., etc.)
# TOGETHER_API_KEY=YOUR-KEY-HERE

# OpenRouter (openrouter/auto, anthropic/claude-3.5-sonnet, etc.)
# OPENROUTER_API_KEY=sk-or-YOUR-KEY-HERE

# Mistral (mistral/mistral-large-latest, etc.)
# MISTRAL_API_KEY=YOUR-KEY-HERE

# Cohere (cohere/command-r-plus, etc.)
# COHERE_API_KEY=YOUR-KEY-HERE

# ── Global Model Override ─────────────────────────────────────────────────
# If set, ALL agents use this single model (ignores per-agent routing).
# Useful for free-tier usage or testing with a single model.
# LLM_MODEL=gemini/gemini-2.5-flash

# ── Default Model ─────────────────────────────────────────────────────────
# Fallback model when no per-agent model is configured.
DEFAULT_MODEL=gpt-4o

# ── Per-Agent Model Routing ───────────────────────────────────────────────
# Assign different models to different tasks for cost/quality optimization.
# Use LiteLLM model format: provider/model-name
#
# PLANNER_MODEL=gpt-4o                           # Complex reasoning
# CODER_MODEL=deepseek/deepseek-chat              # Code generation (cheap + good)
# TESTER_MODEL=groq/llama-3.3-70b-versatile       # Test generation (fast + free)
# DEBUGGER_MODEL=anthropic/claude-sonnet-4-5       # Error fixing (strong reasoning)
# CRITIC_MODEL=anthropic/claude-sonnet-4-5         # Code review (needs judgement)
# RESEARCHER_MODEL=gpt-4o                         # Literature analysis
# EXPERIMENT_MODEL=deepseek/deepseek-chat          # Experiment design
# PAPER_WRITER_MODEL=gpt-4o                       # Academic writing
# FIGURE_MODEL=gpt-4o                             # Visualization code

# ── Example: All-Free Configuration ──────────────────────────────────────
# Uncomment these to run entirely on free APIs:
#
# GEMINI_API_KEY=your-gemini-key
# LLM_MODEL=gemini/gemini-2.5-flash
#
# — OR use Groq's free tier: —
# GROQ_API_KEY=your-groq-key
# LLM_MODEL=groq/llama-3.3-70b-versatile

# ── Example: Cost-Optimized Configuration ────────────────────────────────
# Use cheap models for simple tasks, strong models for critical reasoning:
#
# DEEPSEEK_API_KEY=your-key
# OPENAI_API_KEY=your-key
# DEFAULT_MODEL=deepseek/deepseek-chat
# PLANNER_MODEL=gpt-4o
# CODER_MODEL=deepseek/deepseek-chat
# TESTER_MODEL=deepseek/deepseek-chat
# DEBUGGER_MODEL=gpt-4o
# CRITIC_MODEL=gpt-4o
# RESEARCHER_MODEL=gpt-4o
# PAPER_WRITER_MODEL=gpt-4o

# ── Model Tuning ──────────────────────────────────────────────────────────
# Temperature for all LLM calls (consistent across all modes)
LLM_TEMPERATURE=0.0

# Seed for reproducible outputs (0 = disable, any other int = enable)
LLM_SEED=42

# ── Efficiency Settings ───────────────────────────────────────────────────
# Response caching (dedup identical prompts within a run)
LLM_CACHE_ENABLED=1

# Retry on transient failures (rate limits, timeouts, 5xx errors)
LLM_MAX_RETRIES=3

# Rate limit (requests per minute). 0 = unlimited.
# Set this if your provider has RPM limits (e.g., Gemini free tier = 15 RPM)
LLM_RPM_LIMIT=0

# ── Local Models (Ollama) ─────────────────────────────────────────────────
# For running with local models via Ollama or any OpenAI-compatible server:
# LLM_MODE=local
# LOCAL_LLM_URL=http://localhost:11434/v1
# LOCAL_MODEL=deepseek-coder

# ── Server ─────────────────────────────────────────────────────────────────
PORT=8000

# ── Sandbox ────────────────────────────────────────────────────────────────
SANDBOX_IMAGE=python:3.11-slim
SANDBOX_TIMEOUT=300
