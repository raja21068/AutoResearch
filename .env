# ── LLM Provider ──────────────────────────────────────────
LLM_MODE=litellm
DEEPSEEK_API_KEY=*********your_API_KEY**********

# ── All Agents → DeepSeek (free & generous) ───────────────
DEFAULT_MODEL=deepseek/deepseek-chat
PLANNER_MODEL=deepseek/deepseek-chat
CODER_MODEL=deepseek/deepseek-chat
TESTER_MODEL=deepseek/deepseek-chat
DEBUGGER_MODEL=deepseek/deepseek-chat
CRITIC_MODEL=deepseek/deepseek-chat
RESEARCHER_MODEL=deepseek/deepseek-chat
PAPER_WRITER_MODEL=deepseek/deepseek-chat
EXPERIMENT_MODEL=deepseek/deepseek-chat

# ── Rate Limiting (protect your quota) ────────────────────
LLM_RPM_LIMIT=30
LLM_MAX_RETRIES=3
LLM_CACHE_ENABLED=1
LLM_TEMPERATURE=0.0
LLM_SEED=42

# ── Sandbox (no Docker) ───────────────────────────────────
SANDBOX_TIMEOUT=60
SANDBOX_PYTHON=python
CONDA_PYTHON_PATH=your_path\python.exe

# ── Packages ──────────────────────────────────────────────
AVAILABLE_PACKAGES=numpy,pandas,scipy,scikit-learn,matplotlib,torch

# ── Server ────────────────────────────────────────────────
PORT=8000